# Zerodha Kite Connect API Configuration
# Get these from your Kite Connect app: https://developers.kite.trade/

KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_REDIRECT_URL=http://localhost:3000/auth/callback

# For production deployment on Vercel, add these as environment variables
# in your Vercel dashboard: https://vercel.com/dashboard

# Note: Never commit actual credentials to version control
